rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is the designated Administrator
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'rVjVo93UBFPv6zysToWIfi4htG23';
    }

    // User profiles and metadata
    match /users/{userId} {
      // Admin can read all users, individuals can read/write only their own profiles
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow write: if request.auth != null && request.auth.uid == userId;

      // Access to nested user files/subcollections
      match /{document=**} {
        allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Global file upload records (if stored in a root collection)
    match /files/{fileId} {
      // Admin can read all files, users can only read/write their own files
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
